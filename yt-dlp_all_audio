        default="6663000",
        nargs="?",
    )

    parser.add_argument(
        "--download-archive",
        type=pathlib.Path,
        help="Download only videos not listed in the archive file. Record the IDs of all downloaded videos in it",
        metavar="FILE",
        default="archive.yt_dlp_archive",
        nargs="?",
    )

    parser.add_argument(
        "--concurrent-fragments",
        "-N",
        type=int,
        help="Number of fragments of a dash/hlsnative video that should be downloaded concurrently (default is 42)",
        metavar="N",
        default=42,
        nargs="?",
    )

    parser.add_argument(
        "--cookies",
        type=pathlib.Path,
        help="Path to the cookies.txt file for authentication",
        metavar="FILE",
        default="cookies.txt",
        nargs="?",
    )

    parsed_arguments = parser.parse_args()

    argument_url: str = parsed_arguments.url
    argument_ratelimit: float = parsed_arguments.ratelimit
    argument_download_archive: pathlib.Path = parsed_arguments.download_archive
    argument_concurrent_fragments: int = parsed_arguments.concurrent_fragments
    cookies_path: pathlib.Path = parsed_arguments.cookies
    sys.exit(main(argument_url, argument_ratelimit, argument_download_archive, argument_concurrent_fragments, cookies_path))
